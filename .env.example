# LCLG — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit it.

# ---------------------------------------------------------------------------
# Integration mode — controls how LangChain connects to the gateway.
# Options: explicit-managed | explicit-selfhosted | proxy-managed | proxy-selfhosted
# Default: explicit-managed
# ---------------------------------------------------------------------------
LCLG_MODE=explicit-managed

# ---------------------------------------------------------------------------
# Axemere Managed Gateway — required for *-managed modes
# ---------------------------------------------------------------------------

# Bearer token from the Axemere console (Settings → API Keys).
# Not required for self-hosted / Free Gateway modes.
AXEMERE_GATEWAY_TOKEN=axemere_k_your_token_here

# Gateway URL. Override for self-hosted or Free Gateway: http://localhost:7080
# Default: https://us.gw.axemere.ai
# AXEMERE_GATEWAY_URL=https://us.gw.axemere.ai

# Project ID for attribution and cost tracking (Configure → Projects).
# Required by the default gateway policy.
AXEMERE_PROJECT_ID=prj_lclg_demo

# Default workload ID. Each agent overrides this per-call with its own wl_lclg_*
# workload. This value is the fallback if no per-agent override is set.
# AXEMERE_WORKLOAD_ID=wl_lclg_demo

# Optional attribution fields for cost chargeback.
# AXEMERE_CUSTOMER_ID=
# AXEMERE_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Pipeline settings
# ---------------------------------------------------------------------------

# Maximum sub-questions the PlannerAgent will generate.
# More sub-questions → more research calls → higher cost and latency.
# Default: 4
# LCLG_MAX_SUB_QUESTIONS=4

# Directory for generated HTML and Markdown reports.
# Each run creates a subdirectory: output/<run_id>/
# Default: ./output
# LCLG_OUTPUT_DIR=./output

# ---------------------------------------------------------------------------
# Optional — Gateway admin token (self-hosted / proxy-selfhosted mode only)
# Enables full gateway metering for streaming agents (analyst, reporter) in
# proxy modes. When set, the pipeline fetches token counts and cost from
# GET /v1/records/{id} after each streaming call. Without this, streaming
# agents show 0 tokens (the gateway still records them, but the app can't
# retrieve the data without admin access).
#
# For the Free / Docker gateway, find the admin token in your gateway config.
# For the Axemere Managed Gateway, admin tokens are not available to users —
# leave this unset and use the Axemere console to view per-call metering.
# ---------------------------------------------------------------------------
# MVGC_ADMIN_TOKEN=your_gateway_admin_token_here

# ---------------------------------------------------------------------------
# Optional — Tavily web search
# Enables real web search in the ResearchAgent.
# Without this key, the agent uses the model's training knowledge instead,
# and the report annotates findings as "Model Knowledge" rather than "Web Search".
# Free tier: 1,000 searches/month — https://app.tavily.com
# ---------------------------------------------------------------------------
# TAVILY_API_KEY=tvly-your_key_here
